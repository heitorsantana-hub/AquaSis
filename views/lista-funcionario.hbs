<div class="flex justify-between items-center mb-6">
    <div>
        <h3 class="text-xl font-bold text-slate-800">Equipe Ativa</h3>
        <p class="text-sm text-slate-500">Gerencie os acessos dos auxiliares e visualize a equipe do laboratório.</p>
    </div>
    <a href="/funcionarios/novo" class="bg-sky-600 text-white px-4 py-2 rounded-lg font-medium hover:bg-sky-700 transition-colors shadow-sm">
        <i class="fa-solid fa-user-plus mr-2"></i> Adicionar Auxiliar
    </a>
</div>

<div class="bg-white rounded-xl shadow-sm overflow-hidden border border-slate-200">
    <div class="overflow-x-auto">
        <table class="w-full text-left border-collapse">
            <thead>
                <tr class="bg-slate-50 text-slate-500 text-sm border-b border-slate-200">
                    <th class="py-4 px-6 font-semibold uppercase tracking-wider">Funcionário</th>
                    <th class="py-4 px-6 font-semibold uppercase tracking-wider">E-mail</th>
                    <th class="py-4 px-6 font-semibold uppercase tracking-wider">Cargo</th>
                    <th class="py-4 px-6 font-semibold uppercase tracking-wider">Status</th>
                    <th class="py-4 px-6 font-semibold uppercase tracking-wider text-right">Ações</th>
                </tr>
            </thead>
            <tbody class="text-sm divide-y divide-slate-100">
                {{#each funcionarios}}
                <tr class="hover:bg-slate-50 transition-colors">
                    <td class="py-4 px-6">
                        <div class="flex items-center gap-3">
                            <div class="w-8 h-8 rounded-full bg-sky-100 text-sky-600 flex items-center justify-center font-bold text-xs">
                                {{this.iniciais}}
                            </div>
                            <span class="font-semibold text-slate-700">{{this.nome}}</span>
                        </div>
                    </td>
                    <td class="py-4 px-6 text-slate-600">{{this.email}}</td>
                    <td class="py-4 px-6">
                        <span class="px-2 py-1 rounded-md text-xs font-medium 
                            {{#if (eq this.cargo 'Químico')}}bg-indigo-100 text-indigo-700{{else}}bg-slate-100 text-slate-700{{/if}}">
                            {{this.cargo}}
                        </span>
                    </td>
                    <td class="py-4 px-6">
                        <span class="flex items-center gap-1.5 text-emerald-600 font-medium">
                            <span class="w-2 h-2 bg-emerald-500 rounded-full"></span> Ativo
                        </span>
                    </td>
                    <td class="py-4 px-6 text-right">
                        {{#if (eq this.cargo 'Auxiliar')}}
                        <button onclick="confirmarDesativacao('{{this.id}}', '{{this.nome}}')" class="text-red-500 hover:text-red-700 font-medium hover:bg-red-50 px-3 py-1.5 rounded transition-colors" title="Desativar Acesso">
                            <i class="fa-solid fa-user-slash"></i> Desativar
                        </button>
                        {{else}}
                        <span class="text-slate-400 italic text-xs">Sistema</span>
                        {{/if}}
                    </td>
                </tr>
                {{/each}}
            </tbody>
        </table>
    </div>
</div>

<script>
    async function confirmarDesativacao(id, nome) {
        if (confirm(`Tem certeza que deseja desativar o acesso de ${nome}? Ele não poderá mais logar no sistema.`)) {
            
            try {
                // Faz a requisição POST silenciosa
                const response = await fetch(`/funcionarios/desativar/${id}`, {
                    method: 'POST'
                });

                if (response.ok) {
                    // Deu certo! Recarrega a página para o usuário sumir da lista
                    window.location.reload();
                } else {
                    alert('Erro ao tentar desativar o funcionário.');
                }
            } catch (error) {
                console.error('Erro de conexão:', error);
                alert('Falha na comunicação com o servidor.');
            }

        }
    }
</script>