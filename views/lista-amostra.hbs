<div class="flex items-center justify-between mb-6">
    <div>
        <h1 class="text-2xl font-semibold text-slate-800">Amostras</h1>
        <p class="text-sm text-slate-500 mt-1">Gestão e rastreabilidade de todas as amostras laboratoriais.</p>
    </div>
    <a href="/amostras/nova" class="bg-sky-600 hover:bg-sky-700 text-white text-sm font-medium py-2 px-4 rounded-lg shadow-sm transition-colors flex items-center gap-2">
        <i class="fa-solid fa-plus"></i> Receber Nova Amostra
    </a>
</div>

<div id="alert-container" class="mb-6"></div>

<div class="bg-white rounded-lg shadow-sm border border-slate-200 overflow-hidden">
    <div class="overflow-x-auto">
        <table class="w-full text-left border-collapse">
            <thead>
                <tr class="bg-slate-50 border-b border-slate-200 text-slate-500 text-xs uppercase tracking-wider">
                    <th class="p-4 font-medium">Protocolo</th>
                    <th class="p-4 font-medium">Cliente</th>
                    <th class="p-4 font-medium">Tipo / Coleta</th>
                    <th class="p-4 font-medium">Status</th>
                    <th class="p-4 font-medium text-right">Ações</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-slate-200 text-sm">
                {{#each amostras}}
                <tr class="hover:bg-slate-50/50 transition-colors">
                    
                    <td class="p-4">
                        <p class="font-bold text-sky-700">{{this.protocolo}}</p>
                        <p class="text-xs text-slate-500 mt-0.5"><i class="fa-regular fa-clock"></i> Rec: {{this.data_recebimento}}</p>
                    </td>
                    
                    <td class="p-4">
                        <p class="font-semibold text-slate-800">{{this.cliente_nome}}</p>
                    </td>

                    <td class="p-4">
                        <p class="text-slate-700">{{this.tipo_amostra}}</p>
                        <p class="text-slate-500 text-xs mt-1">Coleta: {{this.data_coleta}} às {{this.hora_coleta}}</p>
                    </td>
                    
                    <td class="p-4">
                        {{#if (eq this.status 'Recebida')}}
                            <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-amber-100 text-amber-700 border border-amber-200">
                                <i class="fa-solid fa-box-open mr-1.5"></i> Recebida
                            </span>
                        {{else if (eq this.status 'Em Análise')}}
                            <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-sky-100 text-sky-700 border border-sky-200">
                                <i class="fa-solid fa-flask mr-1.5"></i> Em Análise
                            </span>
                        {{else}}
                            <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-emerald-100 text-emerald-700 border border-emerald-200">
                                <i class="fa-solid fa-check-double mr-1.5"></i> Concluído
                            </span>
                        {{/if}}
                    </td>
                    
                    <td class="p-4">
                        <div class="flex items-center justify-end gap-2">
                            
                            <button type="button" onclick="openEditModal(this)"
                                data-id="{{this._id}}"
                                data-protocolo="{{this.protocolo}}"
                                data-status="{{this.status}}"
                                data-tipo="{{this.tipo_amostra}}"
                                class="w-8 h-8 rounded-md flex items-center justify-center text-sky-600 hover:bg-sky-50 border border-transparent hover:border-sky-200 transition-colors"
                                title="Editar Amostra">
                                <i class="fa-solid fa-pen"></i>
                            </button>

                            <form action="/amostras/deletar" method="POST" onsubmit="return confirm('ATENÇÃO: A exclusão da amostra {{this.protocolo}} apagará também todos os resultados vinculados. Deseja continuar?')" class="m-0">
                                <input type="hidden" name="amostra_id" value="{{this._id}}">
                                <button type="submit" 
                                    class="w-8 h-8 rounded-md flex items-center justify-center text-rose-500 hover:bg-rose-50 border border-transparent hover:border-rose-200 transition-colors"
                                    title="Excluir Amostra">
                                    <i class="fa-solid fa-trash-can"></i>
                                </button>
                            </form>

                        </div>
                    </td>
                </tr>
                {{else}}
                <tr>
                    <td colspan="5" class="p-12 text-center">
                        <div class="inline-flex items-center justify-center w-16 h-16 rounded-full bg-slate-100 mb-4 text-slate-400 text-2xl">
                            <i class="fa-solid fa-vials"></i>
                        </div>
                        <h3 class="text-lg font-medium text-slate-800 mb-1">Nenhuma amostra encontrada</h3>
                        <p class="text-slate-500 text-sm">Aceda a "Receber Nova Amostra" para dar entrada num serviço.</p>
                    </td>
                </tr>
                {{/each}}
            </tbody>
        </table>
    </div>
</div>

<div id="editAmostraModal" class="fixed inset-0 bg-slate-900/60 backdrop-blur-sm z-50 hidden flex items-center justify-center">
    <div class="bg-white rounded-xl shadow-xl w-full max-w-md overflow-hidden">
        
        <div class="px-6 py-4 border-b border-slate-200 flex justify-between items-center">
            <h2 class="text-lg font-semibold text-slate-800">Editar Amostra <span id="modal-protocol-display" class="text-sky-600"></span></h2>
            <button onclick="closeEditModal()" class="text-slate-400 hover:text-slate-600 transition-colors">
                <i class="fa-solid fa-xmark text-xl"></i>
            </button>
        </div>
        
        <form id="editForm" method="POST">
            <div class="p-6 space-y-5 text-sm">
                
                <div>
                    <label class="block text-slate-700 font-medium mb-1">Tipo de Amostra</label>
                    <input type="text" name="tipo_amostra" id="edit-tipo" class="w-full border border-slate-300 rounded-lg px-3 py-2 outline-none focus:border-sky-500 focus:ring-1 focus:ring-sky-500 transition-all" required>
                </div>
                
                <div>
                    <label class="block text-slate-700 font-medium mb-1">Mudar Status da Análise</label>
                    <select name="status" id="edit-status" class="w-full border border-slate-300 rounded-lg px-3 py-2 outline-none focus:border-sky-500 focus:ring-1 focus:ring-sky-500 transition-all">
                        <option value="Recebida">Recebida</option>
                        <option value="Em Análise">Em Análise</option>
                        <option value="Concluído">Concluído</option>
                    </select>
                </div>
                
                <div class="bg-amber-50 border border-amber-200 rounded p-3 flex gap-2 text-amber-800">
                    <i class="fa-solid fa-circle-info mt-0.5"></i>
                    <p class="text-xs">Para alterar clientes, análises ou resultados, aceda ao painel detalhado de Relatórios.</p>
                </div>

            </div>
            
            <div class="px-6 py-4 bg-slate-50 border-t border-slate-200 flex justify-end gap-3">
                <button type="button" onclick="closeEditModal()" class="px-4 py-2 text-slate-600 hover:bg-slate-200 font-medium rounded-lg transition-colors">Cancelar</button>
                <button type="submit" class="px-4 py-2 bg-sky-600 hover:bg-sky-700 text-white font-medium rounded-lg shadow-sm transition-colors">Atualizar Amostra</button>
            </div>
        </form>
    </div>
</div>

<script>
    // 1. Alertas de Sucesso
    document.addEventListener("DOMContentLoaded", () => {
        const urlParams = new URLSearchParams(window.location.search);
        const alertContainer = document.getElementById('alert-container');
        
        if (urlParams.get('success') === 'edit' || urlParams.get('success') === 'delete') {
            const msg = urlParams.get('success') === 'edit' ? 'Amostra atualizada com sucesso!' : 'Amostra e resultados excluídos com sucesso!';
            alertContainer.innerHTML = `
                <div class="bg-emerald-50 border border-emerald-200 text-emerald-700 px-4 py-3 rounded-lg flex items-center gap-3">
                    <i class="fa-solid fa-circle-check text-lg"></i>
                    <p class="font-medium text-sm">${msg}</p>
                </div>
            `;
            window.history.replaceState(null, '', window.location.pathname);
            setTimeout(() => { alertContainer.innerHTML = ''; }, 5000);
        }
    });

    // 2. Lógica do Modal de Edição
    const modal = document.getElementById('editAmostraModal');

    function openEditModal(button) {
        const id = button.getAttribute('data-id');
        const protocolo = button.getAttribute('data-protocolo');
        const status = button.getAttribute('data-status');
        const tipo = button.getAttribute('data-tipo');

        // Preenche o formulário e o título do modal
        document.getElementById('modal-protocol-display').innerText = `(${protocolo})`;
        document.getElementById('edit-tipo').value = tipo;
        document.getElementById('edit-status').value = status;
        
        // Direciona o envio do form para a rota de atualização
        document.getElementById('editForm').action = `/amostras/editar/${id}`;

        modal.classList.remove('hidden');
    }

    function closeEditModal() {
        modal.classList.add('hidden');
    }

    // Fecha o modal ao clicar na área escura
    modal.addEventListener('click', function(e) {
        if (e.target === this) {
            closeEditModal();
        }
    });
</script>