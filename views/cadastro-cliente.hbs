<form action="/clientes/salvar" method="POST" class="bg-white rounded-xl shadow-sm p-8 max-w-4xl mx-auto">
    <div class="border-b border-slate-200 pb-6 mb-6">
        <h3 class="text-lg font-bold text-slate-800">Novo Cliente</h3>
        <p class="text-sm text-slate-500">Cadastre empresas ou pessoas físicas com dados completos para os laudos.</p>
    </div>

    {{#if erro}}
    <div class="bg-red-50 border border-red-200 text-red-600 px-4 py-3 rounded-lg mb-6 flex items-center gap-2">
        <i class="fa-solid fa-triangle-exclamation"></i>
        <span class="text-sm font-medium">{{erro}}</span>
    </div>
    {{/if}}

    <h4 class="font-semibold text-slate-800 mb-4 border-b border-slate-100 pb-2">Dados Principais</h4>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-8">
        <div class="md:col-span-2">
            <label class="block text-sm font-medium text-slate-700 mb-2">Nome ou Razão Social *</label>
            <input type="text" name="nome" value="{{cliente.nome}}" class="w-full border border-slate-300 rounded-lg p-2.5 outline-none focus:ring-2 focus:ring-sky-500" required>
        </div>
        <div>
            <label class="block text-sm font-medium text-slate-700 mb-2">CNPJ / CPF *</label>
            <input type="text" id="documento" name="documento" placeholder="00.000.000/0001-00" class="w-full border border-slate-300 rounded-lg p-2.5 outline-none focus:ring-2 focus:ring-sky-500" required>
        </div>
        <div>
            <label class="block text-sm font-medium text-slate-700 mb-2">Telefone / WhatsApp</label>
            <input type="text" id="telefone" value="{{cliente.telefone}}"name="telefone" placeholder="(00) 00000-0000" class="w-full border border-slate-300 rounded-lg p-2.5 outline-none focus:ring-2 focus:ring-sky-500">
        </div>
        <div class="md:col-span-2">
            <label class="block text-sm font-medium text-slate-700 mb-2">E-mail Corporativo</label>
            <input type="email" name="email" value="{{cliente.email}}" class="w-full border border-slate-300 rounded-lg p-2.5 outline-none focus:ring-2 focus:ring-sky-500">
        </div>
    </div>

    <h4 class="font-semibold text-slate-800 mb-4 border-b border-slate-100 pb-2">Endereço</h4>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-8">
        <div>
            <label class="block text-sm font-medium text-slate-700 mb-2">CEP</label>
            <div class="relative">
                <input type="text" value="{{cliente.cep}}" id="cep" name="cep" placeholder="00000-000" class="w-full border border-slate-300 rounded-lg p-2.5 outline-none focus:ring-2 focus:ring-sky-500">
                <div id="cep-loading" class="absolute inset-y-0 right-0 pr-3 flex items-center hidden">
                    <i class="fa-solid fa-spinner fa-spin text-sky-600"></i>
                </div>
            </div>
        </div>
        <div class="md:col-span-2">
            <label class="block text-sm font-medium text-slate-700 mb-2">Logradouro (Rua, Av.)</label>
            <input type="text" id="logradouro" value="{{cliente.logradouro}}" name="logradouro" class="w-full border border-slate-300 rounded-lg p-2.5 bg-slate-50 outline-none focus:ring-2 focus:ring-sky-500">
        </div>
        <div>
            <label class="block text-sm font-medium text-slate-700 mb-2">Bairro</label>
            <input type="text" id="bairro" name="bairro" value="{{cliente.bairro}}" class="w-full border border-slate-300 rounded-lg p-2.5 bg-slate-50 outline-none focus:ring-2 focus:ring-sky-500">
        </div>
        <div>
            <label class="block text-sm font-medium text-slate-700 mb-2">Cidade</label>
            <input type="text" id="cidade" name="cidade" value="{{cliente.cidade}}" class="w-full border border-slate-300 rounded-lg p-2.5 bg-slate-50 outline-none focus:ring-2 focus:ring-sky-500">
        </div>
        <div>
            <label class="block text-sm font-medium text-slate-700 mb-2">Estado (UF)</label>
            <input type="text" id="estado" name="estado" value="{{cliente.estado}}" maxlength="2" class="w-full border border-slate-300 rounded-lg p-2.5 bg-slate-50 outline-none focus:ring-2 focus:ring-sky-500 uppercase">
        </div>
    </div>

    <div class="flex justify-end gap-4 pt-4 border-t border-slate-200">
        <a href="/dashboard" class="px-6 py-2.5 border border-slate-300 text-slate-700 font-medium rounded-lg hover:bg-slate-50 transition-colors">Cancelar</a>
        <button type="submit" class="px-6 py-2.5 bg-sky-600 text-white font-medium rounded-lg hover:bg-sky-700 shadow-sm transition-colors">
            <i class="fa-solid fa-save mr-2"></i> Salvar Cliente
        </button>
    </div>
</form>

<script src="https://unpkg.com/imask"></script>
<script>
    // 1. Aplicando Máscaras
    IMask(document.getElementById('documento'), {
        mask: [
            { mask: '000.000.000-00' }, // CPF
            { mask: '00.000.000/0001-00' } // CNPJ
        ]
    });

    IMask(document.getElementById('telefone'), {
        mask: '(00) 00000-0000'
    });

    const cepMask = IMask(document.getElementById('cep'), {
        mask: '00000-000'
    });

    // 2. Lógica do ViaCEP
    const cepInput = document.getElementById('cep');
    const loadingIcon = document.getElementById('cep-loading');

    cepInput.addEventListener('blur', async function() {
        // Limpa o CEP tirando o traço
        const cepValue = cepInput.value.replace(/\D/g, '');
        
        if (cepValue.length === 8) {
            loadingIcon.classList.remove('hidden');
            
            try {
                const response = await fetch(`https://viacep.com.br/ws/${cepValue}/json/`);
                const data = await response.json();

                if (!data.erro) {
                    document.getElementById('logradouro').value = data.logradouro;
                    document.getElementById('bairro').value = data.bairro;
                    document.getElementById('cidade').value = data.localidade;
                    document.getElementById('estado').value = data.uf;
                } else {
                    alert('CEP não encontrado.');
                }
            } catch (error) {
                console.error("Erro ao buscar CEP:", error);
            } finally {
                loadingIcon.classList.add('hidden');
            }
        }
    });
</script>