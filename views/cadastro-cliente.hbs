<form action="/clientes/salvar" method="POST" class="bg-white rounded-xl shadow-sm p-8 max-w-4xl mx-auto">
    <div class="border-b border-slate-200 pb-6 mb-6">
        <h3 class="text-lg font-bold text-slate-800">Novo Cliente</h3>
        <p class="text-sm text-slate-500">Cadastre empresas ou pessoas físicas para vincular às amostras.</p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-6">
        <div class="md:col-span-2">
            <label class="block text-sm font-medium text-slate-700 mb-2">Nome ou Razão Social</label>
            <input type="text" name="nome" class="w-full border border-slate-300 rounded-lg p-2.5 outline-none focus:ring-2 focus:ring-sky-500" required>
        </div>
        <div>
            <label class="block text-sm font-medium text-slate-700 mb-2">CNPJ / CPF</label>
            <input type="text" name="documento" placeholder="00.000.000/0001-00" class="w-full border border-slate-300 rounded-lg p-2.5 outline-none focus:ring-2 focus:ring-sky-500" required>
        </div>
        <div>
            <label class="block text-sm font-medium text-slate-700 mb-2">Telefone / WhatsApp</label>
            <input type="text" name="telefone" placeholder="(00) 00000-0000" class="w-full border border-slate-300 rounded-lg p-2.5 outline-none focus:ring-2 focus:ring-sky-500">
        </div>
        <div class="md:col-span-2">
            <label class="block text-sm font-medium text-slate-700 mb-2">E-mail Corporativo</label>
            <input type="email" name="email" class="w-full border border-slate-300 rounded-lg p-2.5 outline-none focus:ring-2 focus:ring-sky-500">
        </div>
    </div>

    <div class="flex justify-end gap-4 pt-4 border-t border-slate-200">
        <button type="button" class="px-6 py-2.5 border border-slate-300 text-slate-700 font-medium rounded-lg hover:bg-slate-50 transition-colors">Cancelar</button>
        <button type="submit" class="px-6 py-2.5 bg-sky-600 text-white font-medium rounded-lg hover:bg-sky-700 shadow-sm transition-colors">
            <i class="fa-solid fa-save mr-2"></i> Salvar Cliente
        </button>
    </div>
</form>