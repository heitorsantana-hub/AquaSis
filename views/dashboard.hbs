<div class="flex items-center justify-between mb-6">
    <h1 class="text-2xl font-semibold text-slate-800">Visão Geral do Laboratório</h1>
    <a href="/relatorios" class="hidden sm:inline-flex items-center gap-2 bg-sky-600 hover:bg-sky-700 text-white text-sm font-medium py-2 px-4 rounded-lg shadow-sm transition-colors">
        <i class="fa-solid fa-download"></i> Ir para Laudos
    </a>
</div>

<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 mb-6">

    <div class="bg-white rounded-lg shadow-sm p-6 border-l-4 border-sky-500 flex items-center justify-between">
        <div>
            <p class="text-xs font-bold text-sky-600 uppercase tracking-wide mb-1">Amostras (Mês)</p>
            <h3 class="text-2xl font-bold text-slate-800">{{amostrasMes}}</h3>
        </div>
        <i class="fa-solid fa-vials text-3xl text-slate-300"></i>
    </div>

    <div class="bg-white rounded-lg shadow-sm p-6 border-l-4 border-emerald-500 flex items-center justify-between">
        <div>
            <p class="text-xs font-bold text-emerald-500 uppercase tracking-wide mb-1">Laudos Emitidos</p>
            <h3 class="text-2xl font-bold text-slate-800">{{laudosMes}}</h3>
        </div>
        <i class="fa-solid fa-file-signature text-3xl text-slate-300"></i>
    </div>

    <div class="bg-white rounded-lg shadow-sm p-6 border-l-4 border-cyan-500 flex items-center justify-between">
        <div class="w-full mr-4">
            <p class="text-xs font-bold text-cyan-600 uppercase tracking-wide mb-1">Taxa de Conclusão</p>
            <div class="flex items-center gap-3">
                <h3 class="text-2xl font-bold text-slate-800">{{taxaProcessamento}}%</h3>
                <div class="w-full bg-slate-200 rounded-full h-2.5">
                    <div class="bg-cyan-500 h-2.5 rounded-full" style="width: {{taxaProcessamento}}%"></div>
                </div>
            </div>
        </div>
        <i class="fa-solid fa-flask text-3xl text-slate-300"></i>
    </div>

    <div class="bg-white rounded-lg shadow-sm p-6 border-l-4 border-amber-500 flex items-center justify-between">
        <div>
            <p class="text-xs font-bold text-amber-500 uppercase tracking-wide mb-1">Amostras Pendentes</p>
            <h3 class="text-2xl font-bold text-slate-800">{{amostrasPendentes}}</h3>
        </div>
        <i class="fa-solid fa-clock text-3xl text-slate-300"></i>
    </div>

</div>

<div class="grid grid-cols-1 lg:grid-cols-3 gap-6 mb-6">
    <div class="bg-white rounded-lg shadow-sm lg:col-span-2">
        <div class="border-b border-slate-100 p-4 flex justify-between items-center">
            <h6 class="font-bold text-sky-700">Volume de Entrada (Amostras)</h6>
            <button class="text-slate-400 hover:text-slate-600"><i class="fa-solid fa-ellipsis-vertical"></i></button>
        </div>
        <div class="p-4">
            <div class="relative h-72 w-full"><canvas id="myAreaChart"></canvas></div>
        </div>
    </div>

    <div class="bg-white rounded-lg shadow-sm lg:col-span-1">
        <div class="border-b border-slate-100 p-4 flex justify-between items-center">
            <h6 class="font-bold text-sky-700">Tipos de Matriz</h6>
            <button class="text-slate-400 hover:text-slate-600"><i class="fa-solid fa-ellipsis-vertical"></i></button>
        </div>
        <div class="p-4">
            <div class="relative h-60 w-full"><canvas id="myPieChart"></canvas></div>
            <div class="mt-4 flex justify-center gap-4 text-sm text-slate-600">
                <span class="flex items-center gap-1"><i class="fa-solid fa-circle text-sky-500 text-[10px]"></i> Água</span>
                <span class="flex items-center gap-1"><i class="fa-solid fa-circle text-emerald-500 text-[10px]"></i> Efluentes</span>
                <span class="flex items-center gap-1"><i class="fa-solid fa-circle text-cyan-500 text-[10px]"></i> Outros</span>
            </div>
        </div>
    </div>
</div>

<div class="grid grid-cols-1 lg:grid-cols-3 gap-6">

    <div class="bg-white rounded-lg shadow-sm overflow-hidden lg:col-span-2 flex flex-col h-full">
        <div class="border-b border-slate-100 p-4 flex justify-between items-center">
            <h6 class="font-bold text-sky-700">Últimas Amostras Recebidas</h6>
            <a href="/amostras" class="text-sm text-sky-500 hover:text-sky-600 font-medium">Ver Todas</a>
        </div>
        <div class="overflow-x-auto flex-1">
            <table class="w-full text-left text-sm">
                <thead class="bg-slate-50 text-slate-500">
                    <tr>
                        <th class="px-4 py-3 font-medium">Protocolo</th>
                        <th class="px-4 py-3 font-medium">Cliente</th>
                        <th class="px-4 py-3 font-medium">Status</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-slate-100">
                    {{#each ultimasAmostras}}
                    <tr class="hover:bg-slate-50">
                        <td class="px-4 py-3 font-semibold text-slate-700">{{this.protocolo}}</td>
                        <td class="px-4 py-3 text-slate-600">{{this.clientes.nome}}</td>
                        <td class="px-4 py-3">
                            {{#if (eq this.status 'Recebida')}}
                                <span class="px-2 py-1 bg-amber-100 text-amber-700 rounded text-xs font-medium">{{this.status}}</span>
                            {{else if (eq this.status 'Em Análise')}}
                                <span class="px-2 py-1 bg-sky-100 text-sky-700 rounded text-xs font-medium">{{this.status}}</span>
                            {{else}}
                                <span class="px-2 py-1 bg-emerald-100 text-emerald-700 rounded text-xs font-medium">{{this.status}}</span>
                            {{/if}}
                        </td>
                    </tr>
                    {{else}}
                    <tr>
                        <td colspan="3" class="px-4 py-6 text-center text-slate-500">Nenhuma amostra recente.</td>
                    </tr>
                    {{/each}}
                </tbody>
            </table>
        </div>
    </div>

    <div class="bg-gradient-to-br from-sky-700 to-sky-900 rounded-lg shadow-sm p-6 text-white flex flex-col justify-between relative overflow-hidden h-full min-h-[220px]">
        <i class="fa-solid fa-trophy absolute -bottom-6 -right-4 text-9xl text-white/10 transform -rotate-12"></i>
        
        <div class="relative z-10">
            <div class="flex items-center justify-between mb-4">
                <h6 class="font-bold text-sky-200 uppercase tracking-wider text-xs"><i class="fa-solid fa-star mr-1 text-amber-300"></i> Cliente Destaque</h6>
                <span class="bg-white/20 text-white text-[10px] font-bold px-2 py-1 rounded backdrop-blur-sm">Top 1</span>
            </div>
            
            <h3 class="text-2xl font-bold mb-1 truncate" title="{{topClienteNome}}">{{topClienteNome}}</h3>
            <p class="text-sky-200 text-xs mt-1">Maior solicitante de análises.</p>
        </div>
        
        <div class="relative z-10 mt-6 flex items-baseline gap-2">
            <span class="text-5xl font-extrabold tracking-tighter">{{topClienteQuantidade}}</span>
            <span class="text-sky-200 font-medium text-sm">amostras</span>
        </div>
    </div>

</div>

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

<script>
document.addEventListener('DOMContentLoaded', function() {
    
    const linhaLabels = {{{graficoLinhaLabels}}};
    const linhaDados = {{{graficoLinhaDados}}};

    const roscaLabels = {{{graficoRoscaLabels}}}; 
    const roscaDados = {{{graficoRoscaDados}}};

    const ctxArea = document.getElementById('myAreaChart');
    if (ctxArea && linhaLabels && linhaDados) {
        const gradientArea = ctxArea.getContext('2d').createLinearGradient(0, 0, 0, 300);
        gradientArea.addColorStop(0, 'rgba(14, 165, 233, 0.4)');
        gradientArea.addColorStop(1, 'rgba(14, 165, 233, 0.0)');

        new Chart(ctxArea, {
            type: 'line',
            data: {
                labels: linhaLabels,
                datasets: [{
                    label: 'Amostras Recebidas',
                    data: linhaDados,
                    backgroundColor: gradientArea,
                    borderColor: '#0ea5e9',
                    borderWidth: 3,
                    pointBackgroundColor: '#ffffff',
                    pointBorderColor: '#0ea5e9',
                    pointBorderWidth: 2,
                    pointRadius: 4,
                    pointHoverRadius: 6,
                    fill: true,
                    tension: 0.4 
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: {
                    legend: { display: false },
                    tooltip: {
                        backgroundColor: '#0f172a', padding: 12,
                        titleFont: { size: 13, family: 'Inter' },
                        bodyFont: { size: 14, family: 'Inter', weight: 'bold' },
                        callbacks: { label: function(context) { return ' ' + context.parsed.y + ' amostras'; } }
                    }
                },
                scales: {
                    x: { grid: { display: false }, ticks: { color: '#64748b' } },
                    y: {
                        grid: { color: '#f1f5f9', borderDash: [5, 5] },
                        ticks: { color: '#64748b', stepSize: 1 }, 
                        beginAtZero: true
                    }
                }
            }
        });
    }

    const ctxPie = document.getElementById('myPieChart');
    if (ctxPie && roscaLabels && roscaDados) {
        new Chart(ctxPie, {
            type: 'doughnut',
            data: {
                labels: roscaLabels,
                datasets: [{
                    data: roscaDados,
                    backgroundColor: ['#0ea5e9', '#10b981', '#06b6d4', '#f59e0b', '#8b5cf6', '#ec4899'],
                    hoverBackgroundColor: ['#0284c7', '#059669', '#0891b2', '#d97706', '#7c3aed', '#db2777'],
                    borderWidth: 0, hoverOffset: 4
                }]
            },
            options: {
                responsive: true, maintainAspectRatio: false, cutout: '75%',
                plugins: {
                    legend: { display: false }, 
                    tooltip: {
                        backgroundColor: '#0f172a', padding: 12,
                        bodyFont: { size: 14, family: 'Inter', weight: 'bold' },
                        callbacks: { label: function(context) { return ' ' + context.label + ': ' + context.parsed + ' amostras'; } }
                    }
                }
            }
        });
    }
});
</script>