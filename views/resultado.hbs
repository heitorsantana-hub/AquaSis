<form action="/resultados/salvar" method="POST" class="bg-white rounded-xl shadow-sm p-8 max-w-5xl mx-auto">
    
    <!-- Cabeçalho -->
    <div class="flex justify-between items-center border-b border-slate-200 pb-6 mb-6">
        <div>
            <h3 class="text-lg font-bold text-slate-800"><i class="fa-solid fa-flask text-sky-600 mr-2"></i>Lançamento de Resultados</h3>
            <p class="text-sm text-slate-500">Preencha os valores analíticos encontrados para esta amostra.</p>
        </div>
        <div class="text-right">
            <p class="text-sm font-semibold text-slate-500 uppercase tracking-wide">Protocolo</p>
            <div class="text-2xl font-bold text-sky-600 bg-sky-50 px-4 py-2 rounded mt-1 border border-sky-100">{{amostra.protocolo}}</div>
            <!-- Enviamos o ID da amostra oculto para o backend saber quem atualizar -->
            <input type="hidden" name="amostra_id" value="{{amostra.id}}">
        </div>
    </div>

    <!-- Resumo da Amostra (Apenas Leitura) -->
    <div class="bg-slate-50 border border-slate-200 rounded-lg p-5 mb-8 grid grid-cols-1 md:grid-cols-3 gap-4 text-sm">
        <div>
            <span class="block text-slate-500 font-medium mb-1">Cliente</span>
            <span class="font-semibold text-slate-800">{{amostra.clientes.nome}}</span>
        </div>
        <div>
            <span class="block text-slate-500 font-medium mb-1">Tipo de Matriz</span>
            <span class="font-semibold text-slate-800">{{amostra.tipo_amostras.nome}}</span>
        </div>
        <div>
            <span class="block text-slate-500 font-medium mb-1">Data/Hora da Coleta</span>
            <span class="font-semibold text-slate-800">{{amostra.data_coleta}} às {{amostra.hora_coleta}}</span>
        </div>
    </div>

    <!-- Tabela de Lançamento de Parâmetros -->
    <h4 class="font-semibold text-slate-800 mb-4 border-b border-slate-100 pb-2">Parâmetros Solicitados</h4>
    
    <div class="overflow-x-auto mb-8">
        <table class="w-full text-left border-collapse">
            <thead>
                <tr class="bg-slate-50 text-slate-500 text-xs uppercase tracking-wider border-y border-slate-200">
                    <th class="p-4 font-medium w-1/3">Determinação Analítica</th>
                    <th class="p-4 font-medium w-1/4">Unidade</th>
                    <th class="p-4 font-medium w-5/12">Valor Encontrado (Resultado)</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-slate-100">
                
                {{#each resultados}}
                <tr class="hover:bg-slate-50/50 transition-colors">
                    <td class="p-4">
                        <p class="font-semibold text-slate-700">{{this.determinacoes.nome}}</p>
                        <!-- Envia o ID do resultado específico para o backend atualizar a linha certa -->
                        <input type="hidden" name="resultados[{{@index}}][id]" value="{{this.id}}">
                    </td>
                    <td class="p-4 text-slate-500 text-sm">
                        {{this.determinacoes.unidade_medida}}
                    </td>
                    <td class="p-4">
                        <div class="relative">
                            <input type="text" 
                                   name="resultados[{{@index}}][valor]" 
                                   value="{{this.valor_resultado}}" 
                                   placeholder="Ex: 7.4, < 0.01, Ausente..." 
                                   class="w-full border border-slate-300 rounded-lg p-2.5 outline-none focus:ring-2 focus:ring-sky-500 focus:border-sky-500 text-slate-700 font-medium"
                                   required>
                        </div>
                    </td>
                </tr>
                {{else}}
                <tr>
                    <td colspan="3" class="p-8 text-center text-slate-500">
                        <i class="fa-solid fa-triangle-exclamation text-amber-500 text-2xl mb-2 block"></i>
                        Nenhum parâmetro vinculado a esta amostra.
                    </td>
                </tr>
                {{/each}}
                
            </tbody>
        </table>
    </div>

    <div class="bg-sky-50 border border-sky-100 rounded-lg p-4 mb-8 flex gap-3 text-sky-800 text-sm">
        <i class="fa-solid fa-circle-info mt-0.5 text-sky-600"></i>
        <p>Após salvar os resultados, o status desta amostra poderá ser alterado automaticamente para <strong>"Concluído"</strong> no painel de controle.</p>
    </div>

    <!-- Botões de Ação -->
    <div class="flex justify-end items-center gap-4 pt-6 border-t border-slate-200">
        <a href="/lista" class="px-6 py-2.5 border border-slate-300 text-slate-700 font-medium rounded-lg hover:bg-slate-50 transition-colors">
            Cancelar
        </a>
        <button type="submit" class="px-6 py-2.5 bg-emerald-600 text-white font-bold rounded-lg hover:bg-emerald-700 shadow-sm transition-all shadow-emerald-200 hover:shadow-emerald-300 flex items-center">
            <i class="fa-solid fa-check-double mr-2"></i> Salvar Resultados
        </button>
    </div>
</form>