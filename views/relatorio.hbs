<div class="bg-white rounded-xl shadow-sm p-6 mb-8">
    <h3 class="font-bold text-slate-800 mb-4">Filtro de Relatórios</h3>
    
    <form action="/relatorios" method="GET" class="grid grid-cols-1 md:grid-cols-4 gap-4 items-end">
        <div>
            <label class="block text-sm font-medium text-slate-700 mb-2">Data Inicial</label>
            <input type="date" name="dataInicial" value="{{filtros.dataInicial}}" class="w-full border border-slate-300 rounded-lg p-2.5 outline-none focus:ring-2 focus:ring-sky-500">
        </div>
        <div>
            <label class="block text-sm font-medium text-slate-700 mb-2">Data Final</label>
            <input type="date" name="dataFinal" value="{{filtros.dataFinal}}" class="w-full border border-slate-300 rounded-lg p-2.5 outline-none focus:ring-2 focus:ring-sky-500">
        </div>
        <div>
            <label class="block text-sm font-medium text-slate-700 mb-2">Cliente</label>
            <select name="clienteId" class="w-full border border-slate-300 rounded-lg p-2.5 outline-none focus:ring-2 focus:ring-sky-500">
                <option value="">Todos os clientes...</option>
                {{#each clientes}}
                <option value="{{this.id}}" {{#if (eq this.id ../filtros.clienteId)}}selected{{/if}}>
                    {{this.nome}}
                </option>
                {{/each}}
            </select>
        </div>
        <div>
            <button type="submit" class="w-full bg-slate-800 text-white font-medium rounded-lg p-2.5 hover:bg-slate-700 transition-colors">
                <i class="fa-solid fa-filter mr-2"></i> Filtrar
            </button>
        </div>
    </form>
</div>

<div class="bg-white rounded-xl shadow-sm overflow-hidden">
    <div class="px-6 py-4 border-b border-slate-100 flex justify-between items-center">
        <h3 class="font-semibold text-slate-800">Laudos Disponíveis</h3>
    </div>
    <div class="overflow-x-auto">
        <table class="w-full text-left border-collapse">
            <thead>
                <tr class="bg-slate-50 text-slate-500 text-sm">
                    <th class="py-3 px-6 font-medium">Protocolo</th>
                    <th class="py-3 px-6 font-medium">Cliente</th>
                    <th class="py-3 px-6 font-medium">Data</th>
                    <th class="py-3 px-6 font-medium text-right">Ações</th>
                </tr>
            </thead>
            <tbody class="text-sm divide-y divide-slate-100">
                
                {{#each laudos}}
                <tr class="hover:bg-slate-50 transition-colors">
                    <td class="py-4 px-6 font-semibold text-sky-600">{{this.protocolo}}</td>
                    <td class="py-4 px-6 text-slate-700">{{this.clienteNome}}</td>
                    <td class="py-4 px-6 text-slate-600">{{this.dataConclusao}}</td>
                    <td class="py-4 px-6 text-right">
                        <div class="flex justify-end gap-2">
                            <button onclick="notificarCliente('whatsapp', '{{this.protocolo}}')" class="text-emerald-600 hover:text-emerald-800 font-medium bg-emerald-50 px-3 py-1.5 rounded border border-emerald-100 transition-colors" title="Enviar via WhatsApp">
                                <i class="fa-brands fa-whatsapp text-lg"></i>
                            </button>

                            <button onclick="notificarCliente('email', '{{this.protocolo}}')" class="text-indigo-600 hover:text-indigo-800 font-medium bg-indigo-50 px-3 py-1.5 rounded border border-indigo-100 transition-colors" title="Enviar por E-mail">
                                <i class="fa-solid fa-envelope"></i>
                            </button>

                            <a href="/relatorios/download/{{this.protocolo}}" class="text-sky-600 ...">
                                <i class="fa-solid fa-download mr-1"></i> PDF
                            </a>
                        </div>
                    </td>
                </tr>
                {{/each}}
                
                {{#unless laudos}}
                <tr>
                    <td colspan="4" class="py-8 text-center text-slate-500">Nenhum laudo encontrado com os filtros selecionados.</td>
                </tr>
                {{/unless}}

            </tbody>
        </table>
    </div>
</div>

<script>
    async function notificarCliente(canal, protocolo) {
        console.log(`Iniciando envio via ${canal} para o protocolo ${protocolo}...`);
        
        try {
            const response = await fetch(`/api/notificacoes/enviar`, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ protocolo: protocolo, canal: canal })
            });

            if (response.ok) {
                alert(`Notificação enviada com sucesso via ${canal.toUpperCase()}!`);
            } else {
                alert('Erro ao enviar a notificação. Verifique a integração.');
            }
        } catch (error) {
            console.error('Erro de conexão:', error);
            alert('Falha na comunicação com o servidor.');
        }
    }
</script>