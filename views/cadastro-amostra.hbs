<form action="/amostras/salvar" method="POST" class="bg-white rounded-xl shadow-sm p-8 max-w-5xl mx-auto">
    
    <div class="flex justify-between items-center border-b border-slate-200 pb-6 mb-6">
        <div>
            <h3 class="text-lg font-bold text-slate-800">Solicitação de Serviço de Ensaio</h3>
            <p class="text-sm text-slate-500">Preencha os dados de entrada da amostra.</p>
        </div>
        <div class="text-right">
            <p class="text-sm font-semibold text-slate-500 uppercase tracking-wide">Protocolo Gerado</p>
            <div class="text-2xl font-bold text-sky-600 bg-sky-50 px-4 py-2 rounded mt-1">{{novoProtocolo}}</div>
            <input type="hidden" name="protocolo" value="{{novoProtocolo}}">
        </div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-8">
        <div>
            <label class="block text-sm font-medium text-slate-700 mb-2">Cliente / Empresa</label>
            <select name="cliente_id" class="w-full border border-slate-300 rounded-lg p-2.5 focus:ring-2 focus:ring-sky-500 focus:border-sky-500 outline-none" required>
                <option value="" disabled selected>Selecione um cliente cadastrado...</option>
                {{#each clientes}}
                <option value="{{this.id}}">{{this.nome}} ({{this.documento}})</option>
                {{/each}}
            </select>
        </div>
        <div>
            <label class="block text-sm font-medium text-slate-700 mb-2">Tipo de Amostra</label>
            <input type="text" name="tipo_amostra" class="w-full border border-slate-300 rounded-lg p-2.5 focus:ring-2 focus:ring-sky-500 focus:border-sky-500 outline-none" id="" required>
        </div>
        
        <div class="grid grid-cols-2 gap-4">
            <div>
                <label class="block text-sm font-medium text-slate-700 mb-2">Data da Coleta</label>
                <input type="date" name="data_coleta" class="w-full border border-slate-300 rounded-lg p-2.5 outline-none" required>
            </div>
            <div>
                <label class="block text-sm font-medium text-slate-700 mb-2">Hora da Coleta</label>
                <input type="time" name="hora_coleta" class="w-full border border-slate-300 rounded-lg p-2.5 outline-none" required>
            </div>
        </div>

        <div class="grid grid-cols-2 gap-4">
            <div>
                <label class="block text-sm font-medium text-slate-700 mb-2">Data de Recebimento</label>
                <input type="date" name="data_recebimento" value="{{dataAtual}}" class="w-full border border-slate-300 bg-slate-50 rounded-lg p-2.5" readonly>
            </div>
            <div>
                <label class="block text-sm font-medium text-slate-700 mb-2">Hora de Recebimento</label>
                <input type="time" name="hora_recebimento" value="{{horaAtual}}" class="w-full border border-slate-300 bg-slate-50 rounded-lg p-2.5" readonly>
            </div>
        </div>
    </div>

    <h4 class="font-semibold text-slate-800 mb-4 border-b border-slate-100 pb-2">Condições Técnicas de Recebimento</h4>
    <div class="grid grid-cols-2 md:grid-cols-4 gap-6 mb-8 bg-slate-50 p-6 rounded-lg border border-slate-200">
        <div>
            <span class="block text-sm font-medium text-slate-700 mb-2">Recipiente Adequado?</span>
            <label class="inline-flex items-center mr-4 cursor-pointer">
                <input type="radio" name="check_recipiente" value="Sim" class="text-sky-600 focus:ring-sky-500" required> <span class="ml-2 text-sm">Sim</span>
            </label>
            <label class="inline-flex items-center cursor-pointer">
                <input type="radio" name="check_recipiente" value="Não" class="text-red-500 focus:ring-red-500"> <span class="ml-2 text-sm">Não</span>
            </label>
        </div>
        <div>
            <span class="block text-sm font-medium text-slate-700 mb-2">Volume Adequado?</span>
            <label class="inline-flex items-center mr-4 cursor-pointer">
                <input type="radio" name="check_volume" value="Sim" class="text-sky-600 focus:ring-sky-500" required> <span class="ml-2 text-sm">Sim</span>
            </label>
            <label class="inline-flex items-center cursor-pointer">
                <input type="radio" name="check_volume" value="Não" class="text-red-500 focus:ring-red-500"> <span class="ml-2 text-sm">Não</span>
            </label>
        </div>
        <div>
            <span class="block text-sm font-medium text-slate-700 mb-2">Refrigeração?</span>
            <label class="inline-flex items-center mr-4 cursor-pointer">
                <input type="radio" name="check_refrigeracao" value="Sim" class="text-sky-600 focus:ring-sky-500" required> <span class="ml-2 text-sm">Sim</span>
            </label>
            <label class="inline-flex items-center mr-4 cursor-pointer">
                <input type="radio" name="check_refrigeracao" value="Não" class="text-red-500 focus:ring-red-500"> <span class="ml-2 text-sm">Não</span>
            </label>
            <label class="inline-flex items-center cursor-pointer">
                <input type="radio" name="check_refrigeracao" value="N.A." class="text-slate-500 focus:ring-slate-500"> <span class="ml-2 text-sm">N.A.</span>
            </label>
        </div>
        <div>
            <span class="block text-sm font-medium text-slate-700 mb-2">Acidificação?</span>
            <label class="inline-flex items-center mr-4 cursor-pointer">
                <input type="radio" name="check_acidificacao" value="Sim" class="text-sky-600 focus:ring-sky-500" required> <span class="ml-2 text-sm">Sim</span>
            </label>
            <label class="inline-flex items-center mr-4 cursor-pointer">
                <input type="radio" name="check_acidificacao" value="Não" class="text-red-500 focus:ring-red-500"> <span class="ml-2 text-sm">Não</span>
            </label>
            <label class="inline-flex items-center cursor-pointer">
                <input type="radio" name="check_acidificacao" value="N.A." class="text-slate-500 focus:ring-slate-500"> <span class="ml-2 text-sm">N.A.</span>
            </label>
        </div>
    </div>

    <h4 class="font-semibold text-slate-800 mb-4 border-b border-slate-100 pb-2">Análises Solicitadas</h4>
    <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-8">
        {{#each analisesDisponiveis}}
        <label class="flex items-center p-3 border border-slate-200 rounded-lg hover:bg-sky-50 cursor-pointer transition-colors">
            <input type="checkbox" name="analises[]" value="{{this.id}}" class="w-5 h-5 text-sky-600 rounded focus:ring-sky-500 border-slate-300">
            <span class="ml-3 text-sm text-slate-700 font-medium">{{this.nome}}</span>
        </label>
        {{/each}}
    </div>

    <div class="mb-8">
        <label class="block text-sm font-medium text-slate-700 mb-2">Observações Adicionais (Ex: Cloro livre, análises customizadas)</label>
        <textarea name="observacoes" rows="3" class="w-full border border-slate-300 rounded-lg p-3 outline-none focus:ring-2 focus:ring-sky-500 focus:border-sky-500"></textarea>
    </div>

    <div class="flex justify-end gap-4 pt-4 border-t border-slate-200">
        <button type="button" class="px-6 py-2.5 border border-slate-300 text-slate-700 font-medium rounded-lg hover:bg-slate-50 transition-colors">Cancelar</button>
        <button type="submit" class="px-6 py-2.5 bg-sky-600 text-white font-medium rounded-lg hover:bg-sky-700 shadow-sm transition-colors shadow-sky-200">
            <i class="fa-solid fa-check mr-2"></i> Registrar Amostra
        </button>
    </div>
</form>