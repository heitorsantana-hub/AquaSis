<script>
    document.addEventListener("DOMContentLoaded", () => {
        // Pega todas as imagens que têm a classe 'header-slide'
        const slides = document.querySelectorAll('.header-slide');
        let slideAtual = 0;

        if(slides.length > 0) {
            setInterval(() => {
                slides[slideAtual].classList.remove('opacity-100');
                slides[slideAtual].classList.add('opacity-0');

                slideAtual = (slideAtual + 1) % slides.length;

                slides[slideAtual].classList.remove('opacity-0');
                slides[slideAtual].classList.add('opacity-100');
            }, 4000); 
        }
    });
</script>

