<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>AquaSis - Login CPF/CNPJ</title>
    
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/styles-cliente1.css">
    
</head>
<body>

    <div class="centered-wrapper">
        
        <div class="centered-card">
            
            <div class="brand-header">
                <div class="logo-icon">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z"></path>
                    </svg>
                </div>
                <span class="brand-name">AquaSis</span>
            </div>

            <div class="login-icon-wrapper">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path>
                    <circle cx="12" cy="7" r="4"></circle>
                </svg>
                <h2 class="login-title">Login</h2>
            </div>

            <form class="login-form">
                
                <div class="input-group">
                    <label for="cpf-cnpj">Digite seu CNPJ ou CPF</label>
                    <input type="text" id="cpf-cnpj" name="cpf-cnpj" autocomplete="off">
                </div>

                <div class="toggle-group">
                    <label class="switch">
                        <input type="checkbox" id="remember">
                        <span class="slider"></span>
                    </label>
                    <label for="remember" class="toggle-label">Lembrar dados</label>
                </div>

                <div class="button-group">
                    <a href="/login" class="btn-back">VOLTAR</a>
                    
                    <button type="submit" class="btn-next">AVANÇAR</button>
                </div>

            </form>

        </div>

    </div>

</body>
</html>