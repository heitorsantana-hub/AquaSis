<div class="flex items-center justify-between mb-6">
    <div>
        <h1 class="text-2xl font-semibold text-slate-800">Clientes</h1>
        <p class="text-sm text-slate-500 mt-1">Gerencie a base de clientes e laboratórios parceiros.</p>
    </div>
    <a href="/clientes/novo" class="bg-sky-600 hover:bg-sky-700 text-white text-sm font-medium py-2 px-4 rounded-lg shadow-sm transition-colors flex items-center gap-2">
        <i class="fa-solid fa-plus"></i> Novo Cliente
    </a>
</div>

<div id="alert-container" class="mb-6"></div>

<div class="bg-white rounded-lg shadow-sm border border-slate-200 overflow-hidden">
    <div class="overflow-x-auto">
        <table class="w-full text-left border-collapse">
            <thead>
                <tr class="bg-slate-50 border-b border-slate-200 text-slate-500 text-xs uppercase tracking-wider">
                    <th class="p-4 font-medium">Nome do Cliente</th>
                    <th class="p-4 font-medium">Contato</th>
                    <th class="p-4 font-medium">Status</th>
                    <th class="p-4 font-medium text-right">Ações</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-slate-200 text-sm">
                {{#each clientes}}
                <tr class="hover:bg-slate-50/50 transition-colors">
                    
                    <td class="p-4">
                        <p class="font-semibold text-slate-800">{{this.nome}}</p>
                        <p class="text-xs text-slate-500 mt-0.5">ID: {{this._id}}</p>
                    </td>
                    
                    <td class="p-4">
                        <p class="text-slate-700 flex items-center gap-2"><i class="fa-regular fa-envelope text-slate-400"></i> {{this.email}}</p>
                        <p class="text-slate-500 text-xs mt-1 flex items-center gap-2"><i class="fa-solid fa-phone text-slate-400"></i> {{this.telefone}}</p>
                    </td>
                    
                    <td class="p-4">
                        <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-emerald-100 text-emerald-700 border border-emerald-200">
                            Ativo
                        </span>
                    </td>
                    
                    <td class="p-4">
                        <div class="flex items-center justify-end gap-2">
                            
                            <button type="button" onclick="openEditModal(this)"
                                data-id="{{this._id}}"
                                data-nome="{{this.nome}}"
                                data-email="{{this.email}}"
                                data-telefone="{{this.telefone}}"
                                class="w-8 h-8 rounded-md flex items-center justify-center text-sky-600 hover:bg-sky-50 border border-transparent hover:border-sky-200 transition-colors"
                                title="Editar Cliente">
                                <i class="fa-solid fa-pen"></i>
                            </button>

                            <form action="/clientes/deletar" method="POST" onsubmit="return confirm('Tem certeza que deseja remover este cliente permanentemente?')" class="m-0">
                                <input type="hidden" name="cliente_id" value="{{this._id}}">
                                <button type="submit" 
                                    class="w-8 h-8 rounded-md flex items-center justify-center text-rose-500 hover:bg-rose-50 border border-transparent hover:border-rose-200 transition-colors"
                                    title="Excluir Cliente">
                                    <i class="fa-solid fa-trash-can"></i>
                                </button>
                            </form>

                        </div>
                    </td>
                </tr>
                {{else}}
                <tr>
                    <td colspan="4" class="p-12 text-center">
                        <div class="inline-flex items-center justify-center w-16 h-16 rounded-full bg-slate-100 mb-4 text-slate-400 text-2xl">
                            <i class="fa-solid fa-users-slash"></i>
                        </div>
                        <h3 class="text-lg font-medium text-slate-800 mb-1">Nenhum cliente cadastrado</h3>
                        <p class="text-slate-500 text-sm">Adicione seu primeiro cliente para começar a gerar laudos.</p>
                    </td>
                </tr>
                {{/each}}
            </tbody>
        </table>
    </div>
</div>

<div id="editClientModal" class="fixed inset-0 bg-slate-900/60 backdrop-blur-sm z-50 hidden flex items-center justify-center">
    <div class="bg-white rounded-xl shadow-xl w-full max-w-md overflow-hidden">
        
        <div class="px-6 py-4 border-b border-slate-200 flex justify-between items-center">
            <h2 class="text-lg font-semibold text-slate-800">Editar Cliente</h2>
            <button onclick="closeEditModal()" class="text-slate-400 hover:text-slate-600 transition-colors">
                <i class="fa-solid fa-xmark text-xl"></i>
            </button>
        </div>
        
        <form id="editForm" method="POST">
            <div class="p-6 space-y-4 text-sm">
                
                <div>
                    <label class="block text-slate-700 font-medium mb-1">Nome Completo / Empresa</label>
                    <input type="text" name="nome" id="edit-nome" class="w-full border border-slate-300 rounded-lg px-3 py-2 outline-none focus:border-sky-500 focus:ring-1 focus:ring-sky-500 transition-all" required>
                </div>
                
                <div>
                    <label class="block text-slate-700 font-medium mb-1">Email</label>
                    <input type="email" name="email" id="edit-email" class="w-full border border-slate-300 rounded-lg px-3 py-2 outline-none focus:border-sky-500 focus:ring-1 focus:ring-sky-500 transition-all" required>
                </div>

                <div>
                    <label class="block text-slate-700 font-medium mb-1">Telefone</label>
                    <input type="text" name="telefone" id="edit-telefone" class="w-full border border-slate-300 rounded-lg px-3 py-2 outline-none focus:border-sky-500 focus:ring-1 focus:ring-sky-500 transition-all" required>
                </div>

            </div>
            
            <div class="px-6 py-4 bg-slate-50 border-t border-slate-200 flex justify-end gap-3">
                <button type="button" onclick="closeEditModal()" class="px-4 py-2 text-slate-600 hover:bg-slate-200 font-medium rounded-lg transition-colors">Cancelar</button>
                <button type="submit" class="px-4 py-2 bg-sky-600 hover:bg-sky-700 text-white font-medium rounded-lg shadow-sm transition-colors">Salvar Alterações</button>
            </div>
        </form>

    </div>
</div>

<script>
    // Sistema de Alertas via URL (Ex: ?success=edit)
    document.addEventListener("DOMContentLoaded", () => {
        const urlParams = new URLSearchParams(window.location.search);
        const alertContainer = document.getElementById('alert-container');
        
        if (urlParams.get('success') === 'edit' || urlParams.get('success') === 'delete') {
            const msg = urlParams.get('success') === 'edit' ? 'Cliente atualizado com sucesso!' : 'Cliente removido com sucesso!';
            alertContainer.innerHTML = `
                <div class="bg-emerald-50 border border-emerald-200 text-emerald-700 px-4 py-3 rounded-lg flex items-center gap-3">
                    <i class="fa-solid fa-circle-check text-lg"></i>
                    <p class="font-medium text-sm">${msg}</p>
                </div>
            `;
            // Limpa a URL para o aviso não reaparecer no F5
            window.history.replaceState(null, '', window.location.pathname);
            // Esconde após 4 segundos
            setTimeout(() => { alertContainer.innerHTML = ''; }, 4000);
        }
    });

    // Funções do Modal de Edição
    const modal = document.getElementById('editClientModal');

    function openEditModal(button) {
        // Pega os dados do botão
        const id = button.getAttribute('data-id');
        const nome = button.getAttribute('data-nome');
        const email = button.getAttribute('data-email');
        const telefone = button.getAttribute('data-telefone');

        // Preenche os campos
        document.getElementById('edit-nome').value = nome;
        document.getElementById('edit-email').value = email;
        document.getElementById('edit-telefone').value = telefone;
        
        // Define a rota do formulário
        document.getElementById('editForm').action = `/clientes/editar/${id}`;

        // Mostra o Modal (Remove a classe 'hidden' do Tailwind)
        modal.classList.remove('hidden');
    }

    function closeEditModal() {
        modal.classList.add('hidden');
    }

    // Fecha o modal ao clicar na área escura (fora do card)
    modal.addEventListener('click', function(e) {
        if (e.target === this) {
            closeEditModal();
        }
    });
</script>